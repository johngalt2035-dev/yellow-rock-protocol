{
  "_comment": "Yellow Rock v6.0 Configuration — High-Conflict Interaction Doctrine",
  "version": "6.0",

  "communication_style": {
    "default": "executive",
    "options": ["personal", "executive"]
  },

  "user": {
    "name": "YOUR_NAME",
    "timezone": "America/New_York"
  },

  "contacts": {
    "opposing-counsel": {
      "protocol": "biff",
      "risk_level": "yellow",
      "counterparty_state": "rigid",
      "context": "professional",
      "style": "executive",
      "escalation_threshold": 7,
      "channel": "signal",
      "notes": "Anchor to obligations, timelines, record quality. BIFF default, DEAR MAN for requests."
    },
    "co-parent": {
      "protocol": "yellow-rock",
      "risk_level": "yellow",
      "counterparty_state": "unreachable",
      "context": "family",
      "style": "executive",
      "escalation_threshold": 5,
      "channel": "signal",
      "notes": "Child-focused, logistical, court-readable. Yellow Rock default."
    },
    "difficult-vendor": {
      "protocol": "biff",
      "risk_level": "green",
      "counterparty_state": "rigid",
      "context": "business",
      "style": "executive",
      "escalation_threshold": 5,
      "channel": "signal",
      "notes": "Use contracts, deliverables, deadlines as anchors. OARS if not hostile."
    },
    "team-member": {
      "protocol": "nvc",
      "risk_level": "green",
      "counterparty_state": "reachable",
      "context": "workplace",
      "style": "personal",
      "escalation_threshold": 8,
      "channel": "signal",
      "notes": "Good-faith dialogue. NVC + GIVE/FAST. Switch to BIFF if attacks begin."
    },
    "trusted-colleague": {
      "protocol": "normal",
      "risk_level": "green",
      "counterparty_state": "reachable",
      "context": "professional",
      "style": "personal",
      "escalation_threshold": 9,
      "channel": "signal",
      "notes": "No protocol constraints. Natural communication."
    }
  },

  "protocol_options": [
    "yellow-rock",
    "biff",
    "grey-rock",
    "dear-man",
    "nvc",
    "mi-oars",
    "documentation-first",
    "safety-planning",
    "normal"
  ],

  "risk_levels": ["green", "yellow", "orange", "red"],
  "counterparty_states": ["reachable", "rigid", "unreachable"],
  "contexts": ["family", "business", "workplace", "friends", "academic", "professional"],

  "provider": {
    "default": "openai",
    "options": {
      "openai": {
        "model": "gpt-4o",
        "api_key_env": "OPENAI_API_KEY"
      },
      "anthropic": {
        "model": "claude-sonnet-4-20250514",
        "api_key_env": "ANTHROPIC_API_KEY"
      },
      "xai": {
        "model": "grok-4-1-fast-reasoning",
        "api_key_env": "XAI_API_KEY"
      },
      "gemini": {
        "model": "gemini-2.5-pro",
        "api_key_env": "GOOGLE_AI_API_KEY"
      },
      "ollama": {
        "model": "llama3.2:8b",
        "base_url": "http://localhost:11434"
      }
    }
  },

  "memory": {
    "database": "yellow-rock-memory.db",
    "port": 9077,
    "api_key_env": "GRM_API_KEY",
    "principal_id_env": "GRM_PRINCIPAL_ID",
    "retention_days": 365
  },

  "message_window": {
    "timezone": "America/New_York",
    "start_hour": 7,
    "end_hour": 22,
    "description": "Messages only sent/received during this window"
  },

  "channels": {
    "signal": {
      "enabled": true,
      "provider": "signal-cli"
    },
    "telegram": {
      "enabled": false,
      "bot_token_env": "TELEGRAM_BOT_TOKEN"
    },
    "whatsapp": {
      "enabled": false,
      "provider": "meta-business-api"
    },
    "sms": {
      "enabled": false,
      "provider": "twilio",
      "api_key_env": "TWILIO_AUTH_TOKEN"
    }
  }
}
